# ======================================
# VoiceHR Environment Configuration
# ======================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True

# PostgreSQL (local development)
DB_NAME=voicehr_db
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# Production Database (Neon - used on Render)
# Get your connection string from: https://neon.tech
# DATABASE_URL=postgresql://neondb_owner:password@ep-xxxx.us-east-2.aws.neon.tech/voicehr_db?sslmode=require

# OpenAI (for Whisper API - OPTIONAL)
# Get your key from: https://platform.openai.com/api-keys
# Note: The app works WITHOUT this key (uses free browser speech recognition)
OPENAI_API_KEY=sk-your-openai-api-key-here
